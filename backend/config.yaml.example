llm:
  model: openai/claude-opus-4-6
  api_key: your-api-key-here
  base_url: "https://your-llm-gateway-url/"
  temperature: 0.7
  max_tokens: 4096

memory:
  enabled: true
  debounce_seconds: 30
  max_facts: 100

skills:
  public_path: skills/public
  custom_path: skills/custom
  templates_path: skills/templates
